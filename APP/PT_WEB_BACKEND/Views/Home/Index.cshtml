@model PT_WEB.Models.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="p-5 mb-4 bg-light rounded-3">
    <div class="container-fluid py-3">
        <h1 class="display-5 fw-bold">Laptop Store</h1>
        <p class="col-md-8 fs-5">A simple website to browse laptops, add to cart, and order online.</p>
        <a class="btn btn-primary btn-lg" asp-controller="Products" asp-action="Index">Shop now</a>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h4 mb-0">Featured products</h2>
    <a asp-controller="Products" asp-action="Index">View all</a>
</div>

<div class="row g-4">
    @foreach (var product in Model.FeaturedProducts)
    {
        <div class="col-md-3">
            <div class="card h-100">
                <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height: 180px; object-fit: cover;" />
                <div class="card-body d-flex flex-column">
                    <h3 class="h6">@product.Name</h3>
                    <p class="text-muted small mb-2">@product.Category?.Name</p>
                    <p class="fw-bold text-primary">@product.Price.ToString("N0") VND</p>
                    <a class="btn btn-outline-primary mt-auto" asp-controller="Products" asp-action="Details" asp-route-id="@product.Id">View details</a>
                </div>
            </div>
        </div>
    }
</div>
