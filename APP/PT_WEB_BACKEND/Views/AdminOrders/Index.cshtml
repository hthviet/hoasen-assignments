@model List<PT_WEB.Models.Order>
@{
    ViewData["Title"] = "Manage orders";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Manage orders</h1>
    <a class="btn btn-outline-primary" asp-controller="AdminDashboard" asp-action="Index">Back to dashboard</a>
</div>

<div class="table-responsive">
    <table class="table table-bordered align-middle">
        <thead>
            <tr>
                <th>Order</th>
                <th>Customer</th>
                <th>Date</th>
                <th>Total</th>
                <th>Items</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>#@order.Id</td>
                    <td>
                        <div>@order.UserAccount?.FullName</div>
                        <div class="text-muted small">@order.UserAccount?.Email</div>
                    </td>
                    <td>@order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@order.TotalAmount.ToString("N0") VND</td>
                    <td>
                        @foreach (var item in order.OrderItems)
                        {
                            <div class="small">@item.ProductName x @item.Quantity</div>
                        }
                    </td>
                    <td>
                        <form asp-action="UpdateStatus" method="post" class="d-flex gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@order.Id" />
                            <select name="status" class="form-select form-select-sm">
                                @foreach (var status in PT_WEB.Models.OrderStatus.All)
                                {
                                    if (order.Status == status)
                                    {
                                        <option value="@status" selected>@status</option>
                                    }
                                    else
                                    {
                                        <option value="@status">@status</option>
                                    }
                                }
                            </select>
                            <button class="btn btn-sm btn-primary">Save</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>