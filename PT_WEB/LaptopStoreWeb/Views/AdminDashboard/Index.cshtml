@model PT_WEB.Models.ViewModels.AdminDashboardViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Admin dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Admin dashboard</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-controller="AdminProducts" asp-action="Index">Manage products</a>
        <a class="btn btn-outline-primary" asp-controller="AdminOrders" asp-action="Index">Manage orders</a>
    </div>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-3">
        <input type="date" name="selectedDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" class="form-control" />
    </div>
    <div class="col-md-2 d-grid">
        <button class="btn btn-primary">View report</button>
    </div>
</form>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <p class="text-muted mb-2">Daily revenue</p>
                <h2 class="h4">@Model.DailyRevenue.ToString("N0") VND</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <p class="text-muted mb-2">Monthly revenue</p>
                <h2 class="h4">@Model.MonthlyRevenue.ToString("N0") VND</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <p class="text-muted mb-2">Yearly revenue</p>
                <h2 class="h4">@Model.YearlyRevenue.ToString("N0") VND</h2>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h2 class="h5 mb-3">Revenue in the last 7 days</h2>
        <canvas id="revenueChart" height="120"></canvas>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labels = @Html.Raw(JsonSerializer.Serialize(Model.ChartLabels));
        const values = @Html.Raw(JsonSerializer.Serialize(Model.ChartValues));

        new Chart(document.getElementById('revenueChart'), {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Revenue',
                    data: values,
                    backgroundColor: '#0d6efd'
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });
    </script>
}